# Supabase (public)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role — serveur uniquement (référentiels « Autre », ne jamais exposer au client)
SUPABASE_SERVICE_ROLE_KEY=

# URL publique du site (lien dans les emails admin)
NEXT_PUBLIC_APP_URL=https://votre-domaine.netlify.app

# Brevo — notification à chaque soumission de document
# Clé API v3 (commence par xkeysib-) — PAS la clé SMTP (xsmtpsib-)
# Brevo → SMTP & API → Clés API → Générer une clé API
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@votre-domaine.com
BREVO_SENDER_NAME=Banque Epreuve
ADMIN_NOTIFICATION_EMAIL=admin@votre-domaine.com
